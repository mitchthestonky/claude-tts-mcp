{
  "name": "claude-tts-mcp",
  "version": "0.1.0",
  "description": "Local text-to-speech MCP server for Claude Code using Kokoro. Free, offline, no API keys.",
  "main": "dist/index.js",
  "bin": {
    "claude-tts-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "init": "node dist/cli.js init"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "tts",
    "text-to-speech",
    "kokoro",
    "local",
    "offline"
  ],
  "author": "Mitch Hazelhurst",
  "license": "Apache-2.0",
  "type": "commonjs",
  "files": [
    "dist/",
    "python/"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
